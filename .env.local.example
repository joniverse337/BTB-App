# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Upstash Redis (Rate Limiting — optional, In-Memory-Fallback ohne diese Werte)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Mapbox (PROJ-10 Lagerplätze — Satellitenkarte + Geocoding)
# WICHTIG: Nur URL-restricted Token verwenden (mapbox.com → Tokens → Allowed URLs)
# Spending Cap im Mapbox-Dashboard setzen (Billing → Spending Limit)
# Scopes: styles:read + geocoding — alles andere deaktivieren
NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...

# App URL (CORS-Header — eigene Domain oder http://localhost:3000 lokal)
# Wird in next.config.ts als Access-Control-Allow-Origin verwendet
NEXT_PUBLIC_APP_URL=http://localhost:3000
